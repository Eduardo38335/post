<p style="color: green"><%= notice %></p>

<%= render @post %>

<div>
  <%= link_to "Edit this post", edit_post_path(@post) %> |
  <%= link_to "Back to posts", posts_path %>

  <%= button_to "Destroy this post", @post, method: :delete %>
</div>
<hr>
<h3>Comments</h3>
<div id="comments">
  <% @post.comments.each do |comment| %>
    <p>
      <strong><%= comment.title %></strong><br>
      <%= comment.body %>
    </p>
  <% end %>
</div>

<hr>
<%# ... debajo de la lista de comentarios ... %>

<hr>
<h4>Deja un comentario:</h4>

<%# Inicializamos un objeto comentario vacío relacionado con este post %>
<%= form_with(model: [ @post, @post.comments.build ]) do |form| %>
  
  <%# Campo oculto que Rails llena automáticamente por la anidación [ @post, ... ] %>
  <div>
    <%= form.label :title, "Título del comentario", style: "display: block" %>
    <%= form.text_field :title %>
  </div>

  <div>
    <%= form.label :body, "Tu mensaje", style: "display: block" %>
    <%= form.text_area :body, rows: 3 %>
  </div>

  <div style="margin-top: 10px;">
    <%= form.submit "Publicar Comentario" %>
  </div>
<% end %>